{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20",
            "timeout": 30000,
            "description": "TypeScript type check after file edits"
          }
        ]
      }
    ],
    "PreCommit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx next lint --quiet 2>&1 | head -30",
            "timeout": 30000,
            "description": "Lint check before committing"
          }
        ]
      }
    ]
  }
}
